<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.web.mapper.UserMapper">

    <select id="getById" resultType="com.web.pojo.User">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <select id="getByAccount" resultType="com.web.pojo.User">
        SELECT * FROM users WHERE account = #{account}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users(account, password, nickname, create_time, update_time)
        VALUES (#{account}, #{password}, #{nickname}, NOW(), NOW())
    </insert>

    <update id="updatePassword">
        UPDATE users
        SET password = #{password}, update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>
