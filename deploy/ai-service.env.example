AI_SERVICE_BASE_URL=http://127.0.0.1:9000
AI_SERVICE_TIMEOUT_SECONDS=120

AI_LLM_PROVIDER=xfyun_codingplan
AI_LLM_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
AI_LLM_API_KEY=replace_with_your_xfyun_codingplan_key
AI_LLM_MODEL=astron-code-latest
AI_LLM_TEMPERATURE=0.3
AI_LLM_MAX_TOKENS=1024
AI_LLM_STRIP_THINK=true
AI_LLM_TIMEOUT_SECONDS=120

AI_EMBEDDING_PROVIDER=local_bge_m3
AI_EMBEDDING_MODEL=BAAI/bge-m3
AI_EMBEDDING_DEVICE=cpu
AI_EMBEDDING_HF_ENDPOINT=https://hf-mirror.com
AI_EMBEDDING_CACHE_DIR=./data/huggingface
AI_EMBEDDING_DIMENSIONS=1024
AI_EMBEDDING_NORMALIZE=true
AI_EMBEDDING_BATCH_SIZE=16
AI_EMBEDDING_REMOTE_URL=
AI_EMBEDDING_REMOTE_API_KEY=
AI_EMBEDDING_REMOTE_TIMEOUT_SECONDS=30
# Internal OpenAI-compatible embedding gateway for LightRAG.
# If set, LightRAG EMBEDDING_BINDING_API_KEY must use the same value.
AI_EMBEDDING_GATEWAY_API_KEY=

CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=ecommerce_kb_v1
CHROMA_ANONYMIZED_TELEMETRY=false

# Knowledge retriever switch:
# - chroma (stable default)
# - lightrag (requires LightRAG server healthy, no fallback)
# - lightrag_with_chroma_fallback (recommended trial mode)
KNOWLEDGE_RETRIEVER=chroma
LIGHTRAG_BASE_URL=http://127.0.0.1:9621
LIGHTRAG_API_KEY=
LIGHTRAG_TIMEOUT_SECONDS=60
LIGHTRAG_QUERY_MODE=hybrid

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_neo4j_password

AI_CS_MAX_MESSAGE_LENGTH=800
AI_CS_MAX_HISTORY_TURNS=8
AI_CS_ENABLE_ORDER_TOOLS=true
