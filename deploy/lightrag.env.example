# LightRAG Server Phase 2 example environment
# Date: 2026-04-27
# Notes:
# - Use LightRAG Server REST API as integration mode.
# - Do not switch storage implementation after documents are indexed.
# - Chroma is fallback-only in ai-service; do not use Chroma as LightRAG primary storage.

########################################
# LightRAG Server host/port/auth
########################################
HOST=0.0.0.0
PORT=9621
# Official LightRAG API key auth uses this value with the X-API-Key request header.
LIGHTRAG_API_KEY=replace_with_lightrag_server_api_key
# Optional unauthenticated paths, if supported by the server version.
WHITELIST_PATHS=/docs,/redoc,/openapi.json

########################################
# LLM backend (OpenAI-compatible remote)
########################################
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=sk-replace-with-openai-compatible-key
LLM_MODEL=gpt-4.1-mini

########################################
# Embedding backend through ai-service OpenAI-compatible gateway.
# Keep this key value the same as AI_EMBEDDING_GATEWAY_API_KEY in deploy/ai-service.env.
########################################
# Example uses an OpenAI-compatible embedding gateway.
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://ai-service:9000/v1
EMBEDDING_BINDING_API_KEY=replace_with_same_value_as_ai_embedding_gateway_api_key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=false

########################################
# Storage profile (conservative Phase 2)
########################################
# Use PostgreSQL for KV/vector/doc status and Neo4j for graph.
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# PostgreSQL connection placeholders
POSTGRES_HOST=lightrag-postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=lightrag
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_SSLMODE=prefer

########################################
# Graph backend (Neo4j)
########################################
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_neo4j_password
NEO4J_DATABASE=neo4j
