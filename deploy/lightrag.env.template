# Copy this file to deploy/lightrag.env for runtime use.
# Do not commit real keys or passwords.

HOST=0.0.0.0
PORT=9621

# LightRAG API key auth. ai-service sends this value with X-API-Key.
LIGHTRAG_API_KEY=replace_with_lightrag_server_api_key
WHITELIST_PATHS=/docs,/redoc,/openapi.json

# OpenAI-compatible LLM backend.
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=replace_with_openai_compatible_key
LLM_MODEL=gpt-4.1-mini

# OpenAI-compatible embedding backend.
# Use ai-service OpenAI-compatible embedding gateway (`POST /v1/embeddings`).
# EMBEDDING_BINDING_API_KEY should be the same secret as AI_EMBEDDING_GATEWAY_API_KEY in deploy/ai-service.env.
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://ai-service:9000/v1
EMBEDDING_BINDING_API_KEY=replace_with_same_value_as_ai_embedding_gateway_api_key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=false

# LightRAG storage: PostgreSQL for KV/vector/doc status, Neo4j for graph.
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

POSTGRES_HOST=lightrag-postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=lightrag
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_SSLMODE=prefer

# Neo4j graph storage.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_neo4j_password
NEO4J_DATABASE=neo4j
