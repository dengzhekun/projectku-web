MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=web
NEO4J_PASSWORD=change_me

# Email verification. For local/dev keep console. For real email use smtp.
EMAIL_CODE_MODE=console
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your@qq.com
MAIL_PASSWORD=qq_email_authorization_code
MAIL_SSL_ENABLE=false
MAIL_STARTTLS_ENABLE=true
EMAIL_SENDER_NAME=元气购
EMAIL_CODE_SUBJECT_PREFIX=元气购验证码

# Payment. Keep mock for demo only. Use sdk after merchant config is ready.
ALIPAY_MODE=mock
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=
ALIPAY_MERCHANT_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-domain.example/api/v1/payments/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.example/pay-result
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_SUBJECT_PREFIX=元气购订单

WECHAT_PAY_MODE=mock
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MERCHANT_PRIVATE_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=https://your-domain.example/api/v1/payments/wechat/notify
WECHAT_PAY_RETURN_URL=https://your-domain.example/pay-result
